# AI 解析器配置（优先级：DeepSeek > OpenAI > 自定义）
# 填写任意一个即可启用 AI 解析；不填则使用规则解析器兜底

# DeepSeek（优先）
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_MODEL=deepseek-chat   # 可选，默认 deepseek-chat

# OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini       # 可选，默认 gpt-4o-mini

# 自定义 OpenAI 兼容接口（三项须同时填写）
# AI_BASE_URL=https://your-endpoint/v1
# AI_API_KEY=your-key
# AI_MODEL=your-model

# 服务端口（可选，默认 3001）
# PORT=3001

# ─── 飞书机器人（可选）────────────────────────────────────────────────────────
# 三项都填写才会启动机器人
# FEISHU_BOT_ENABLED=true
# FEISHU_APP_ID=your_feishu_app_id
# FEISHU_APP_SECRET=your_feishu_app_secret

# 安全白名单（至少填一项，否则拒绝所有请求）
# 获取 open_user_id：飞书开发者后台 → 用户信息查询
# FEISHU_ALLOWED_USER_IDS=your_open_user_id_1,your_open_user_id_2
# FEISHU_ALLOWED_CHAT_IDS=

# 权限说明（在飞书开放平台"权限管理"中申请）：
#   接收单聊消息：im:message.p2p_msg:readonly
#   发送消息：    im:message:send_as_bot
#   订阅事件：    im.message.receive_v1（事件与回调 → 事件配置）
# 启用长连接前必须先在本地启动服务，才能在开发者后台保存"使用长连接接收事件"
